/* ══ QR SCANNER ══ */
function openScanner(target) {
  scanTarget = target;
  document.getElementById('scannerOverlay').classList.add('open');
  navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
    .then(s => {
      scannerStream = s;
      const v = document.getElementById('scanVideo');
      v.srcObject = s; v.play();
      scanInterval = setInterval(() => {
        if (v.readyState !== v.HAVE_ENOUGH_DATA) return;
        const c = document.createElement('canvas');
        c.width = v.videoWidth; c.height = v.videoHeight;
        c.getContext('2d').drawImage(v, 0, 0);
        const img = c.getContext('2d').getImageData(0, 0, c.width, c.height);
        const qr  = jsQR(img.data, img.width, img.height);
        if (qr) { closeScanner(); handleQR(qr.data.replace(/^SCAN:/i, '').trim()); }
      }, 200);
    })
    .catch(() => { closeScanner(); showToast('ไม่สามารถเปิดกล้องได้', 'error'); });
}

function closeScanner() {
  if (scanInterval) { clearInterval(scanInterval); scanInterval = null; }
  if (scannerStream) { scannerStream.getTracks().forEach(t => t.stop()); scannerStream = null; }
  document.getElementById('scannerOverlay').classList.remove('open');
}

function handleQR(code) {
  if (scanTarget === 'stocktake') {
    if (!stState.loaded) { showToast('กำลังโหลดข้อมูล กรุณารอสักครู่แล้วสแกนใหม่', 'error'); return; }
    const item = stState.items.find(i => i.code === code);
    if (!item) { showToast(`ไม่พบรหัส ${code} ในรายการนับสต็อกรอบนี้`, 'error'); return; }
    stOpenCount(code);
    return;
  }
  const item = getAllItems().find(i => i.code === code);
  if (!item) { showToast(`ไม่พบรหัส ${code}`, 'error'); return; }
  addToCart(code, scanTarget);
}

/* ══ HELPERS ══ */
const GAS_URL = localStorage.getItem('global_gas_url') || ((typeof __GAS_URL__ !== 'undefined') ? __GAS_URL__ : '');

function callGAS(fn, args, onOk, onFail) {
  // 1. ถ้ารันอยู่บน Google Apps Script Web App (มี google.script.run) ให้ใช้ช่องทางหลักเสมอ เพื่อเลี่ยงปัญหา CORS
  if (typeof google !== 'undefined' && google.script && google.script.run) {
    let done = false;
    const timer = setTimeout(() => { if (!done) { done = true; if (onFail) onFail('timeout'); } }, 20000);
    google.script.run
      .withSuccessHandler(res => {
        if (done) return; done = true; clearTimeout(timer);
        if (res && res.success === false) { if (onFail) onFail(res.error || 'error'); return; }
        onOk(res);
      })
      .withFailureHandler(e => {
        if (done) return; done = true; clearTimeout(timer);
        if (onFail) onFail(e.message);
      })[fn](...args);
    return;
  }
  
  // 2. ถ้ารันแบบโลคอลในเครื่องคอมพิวเตอร์ และมี GAS_URL ค่อยใช้ fetch (ช่องทางสำรอง)
  if (GAS_URL) {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 25000);
    fetch(GAS_URL, {
      method: 'POST', headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({ fn, args: args || [] }), signal: controller.signal
    })
    .then(r => r.json())
    .then(res => {
      clearTimeout(timer);
      if (res && res.success === false) { if (onFail) onFail(res.error || 'error'); return; }
      onOk(res);
    })
    .catch(err => { clearTimeout(timer); if (onFail) onFail(err.message || 'fetch error'); });
    return;
  }
  
  if (onFail) onFail('no GAS');
}

