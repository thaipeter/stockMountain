function submitReceive() {
  if (!receiveCart.length) return;
  const poNo    = document.getElementById('receivePoNo').value.trim();
  const supplier= document.getElementById('receiveSupplier').value.trim();
  const remark  = document.getElementById('receiveRemark').value.trim();
