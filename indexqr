/* ══ SIGNATURE PAD LOGIC ══ */
let sigCanvas, sigCtx;
let isDrawing = false;
let sigMode = 'withdraw';
let isCanvasClean = true;

function initSignaturePad() {
  sigCanvas = document.getElementById('sigCanvas');
  if (!sigCanvas) return;
  sigCtx = sigCanvas.getContext('2d');
  
  // ปรับขนาด canvas ให้เหมาะสมกับ DPI หน้าจอ
  const ratio = window.devicePixelRatio || 1;
  sigCanvas.width = sigCanvas.offsetWidth * ratio;
  sigCanvas.height = sigCanvas.offsetHeight * ratio;
  sigCtx.scale(ratio, ratio);
  
  sigCtx.strokeStyle = '#000000';
  sigCtx.lineWidth = 3;
  sigCtx.lineCap = 'round';
  sigCtx.lineJoin = 'round';

  clearSignatureCanvas();

  // เหตุการณ์เมาส์
  sigCanvas.removeEventListener('mousedown', startDrawing);
  sigCanvas.removeEventListener('mousemove', draw);
  sigCanvas.removeEventListener('mouseup', stopDrawing);
  sigCanvas.removeEventListener('mouseleave', stopDrawing);
  sigCanvas.addEventListener('mousedown', startDrawing);
  sigCanvas.addEventListener('mousemove', draw);
  sigCanvas.addEventListener('mouseup', stopDrawing);
  sigCanvas.addEventListener('mouseleave', stopDrawing);

  // เหตุการณ์สัมผัส (มือถือ)
  sigCanvas.removeEventListener('touchstart', startDrawing);
  sigCanvas.removeEventListener('touchmove', draw);
  sigCanvas.removeEventListener('touchend', stopDrawing);
  sigCanvas.addEventListener('touchstart', startDrawing, { passive: false });
  sigCanvas.addEventListener('touchmove', draw, { passive: false });
  sigCanvas.addEventListener('touchend', stopDrawing);
}

function getCoords(e) {
  const rect = sigCanvas.getBoundingClientRect();
  if (e.touches && e.touches.length > 0) {
    return {
      x: e.touches[0].clientX - rect.left,
      y: e.touches[0].clientY - rect.top
    };
  }
  return {
    x: e.clientX - rect.left,
    y: e.clientY - rect.top
  };
}

function startDrawing(e) {
  e.preventDefault();
  if (isCanvasClean) {
    // ลบลายน้ำ "ลงลายมือชื่อที่นี่" ออกก่อนเริ่มเซ็นจริง
    sigCtx.fillStyle = '#ffffff';
    sigCtx.fillRect(0, 0, sigCanvas.width, sigCanvas.height);
  }
  isDrawing = true;
  isCanvasClean = false;
  const coords = getCoords(e);
  sigCtx.beginPath();
  sigCtx.moveTo(coords.x, coords.y);
}

function draw(e) {
  if (!isDrawing) return;
  e.preventDefault();
  const coords = getCoords(e);
  sigCtx.lineTo(coords.x, coords.y);
  sigCtx.stroke();
}

function stopDrawing() {
  isDrawing = false;
}

function drawSignatureWatermark() {
  if (!sigCtx) return;
  const ratio = window.devicePixelRatio || 1;
  const w = sigCanvas.width / ratio;
  const h = sigCanvas.height / ratio;
  sigCtx.save();
  sigCtx.fillStyle = 'rgba(148, 163, 184, 0.45)';
  sigCtx.font = '600 15px Kanit, Arial, sans-serif';
  sigCtx.textAlign = 'center';
  sigCtx.textBaseline = 'middle';
  sigCtx.fillText('ลงลายมือชื่อที่นี่', w / 2, h / 2);
  sigCtx.restore();
}

function clearSignatureCanvas() {
  if (!sigCtx) return;
  sigCtx.fillStyle = '#ffffff';
  sigCtx.fillRect(0, 0, sigCanvas.width, sigCanvas.height);
  drawSignatureWatermark();
  isCanvasClean = true;
}

function openSignatureModal(mode) {
  sigMode = mode;
  const cart = mode === 'withdraw' ? withdrawCart : borrowCart;
  const itemsContainer = document.getElementById('signatureModalItems');
  if (itemsContainer) {
    itemsContainer.innerHTML = cart.map(item => {
      const imgUrl = getProxyImgUrl(item.imageUrl);
      const iconHtml = imgUrl
        ? `<img src="${imgUrl}" style="width:36px;height:36px;object-fit:cover;border-radius:6px;border:1px solid var(--border);" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
          + `<div style="display:none;width:36px;height:36px;border-radius:6px;background:var(--surface);align-items:center;justify-content:center;font-size:16px;border:1px solid var(--border);">📦</div>`
        : `<div style="width:36px;height:36px;background:var(--surface);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:16px;border:1px solid var(--border);">📦</div>`;
      return `
      <div style="display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);padding-bottom:6px;">
        ${iconHtml}
        <div style="flex:1;min-width:0;text-align:left;">
          <div style="font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(item.name)}</div>
          <div style="font-size:11px;color:var(--text2);font-family:monospace;">${item.code}</div>
        </div>
        <div style="font-size:14px;font-weight:700;color:var(--amber);white-space:nowrap;">x ${item.qty} ${item.unit || 'ชิ้น'}</div>
      </div>`;
    }).join('');
  }
  document.getElementById('signatureModal').classList.add('open');
  setTimeout(initSignaturePad, 200);
}

function closeSignatureModal() {
  document.getElementById('signatureModal').classList.remove('open');
}

/* ══ HISTORY SLIP MODAL LOGIC ══ */
function openHistorySlip(itemName, itemCode, qty, unit, date, type, remark, imageUrl, signatureUrl) {
  document.getElementById('hsItemName').textContent = itemName;
  document.getElementById('hsItemCode').textContent = itemCode;
  document.getElementById('hsQty').textContent = qty + ' ' + unit;
  document.getElementById('hsDateTime').textContent = date;
  document.getElementById('hsType').textContent = type === 'เบิก' ? 'เบิกออก (Withdraw)' : 'ยืมพัสดุ (Borrow)';
  document.getElementById('hsUser').textContent = me.name;
  document.getElementById('hsRemark').textContent = remark && remark !== '-' ? remark : '-';
  
  if (allData.settings && allData.settings.sysName) {
    document.getElementById('hsSysName').textContent = allData.settings.sysName;
  }
  
  // โหลดรูปสินค้า
  const imgContainer = document.getElementById('hsItemImgContainer');
  const imgUrl = getProxyImgUrl(imageUrl);
  if (imgUrl) {
    imgContainer.innerHTML = `<img src="${imgUrl}" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none';this.nextElementSibling.style.display='block'"><span style="display:none;font-size:20px;">📦</span>`;
  } else {
    imgContainer.innerHTML = `<span style="font-size: 20px;">📦</span>`;
  }
  
  // โหลดลายเซ็น
  const sigContainer = document.getElementById('hsSignatureContainer');
  if (signatureUrl && signatureUrl.trim() !== '') {
    sigContainer.innerHTML = `<img src="${signatureUrl}" style="max-width:100%;max-height:100%;object-fit:contain;">`;
  } else {
    sigContainer.innerHTML = `<span style="font-style: italic; color: #94a3b8; font-size: 12px;">ไม่มีลายเซ็น</span>`;
  }
  
  document.getElementById('historySlipModal').classList.add('open');
}

function closeHistorySlipModal() {
  document.getElementById('historySlipModal').classList.remove('open');
}

function submitCartWithSignature() {
  if (isCanvasClean) {
    Swal.fire({
      icon: 'warning',
      title: 'กรุณาเซ็นลายเซ็น',
      text: 'จำเป็นต้องลงลายเซ็นก่อนส่งคำขอครับ',
      confirmButtonColor: '#ffca28',
      background: '#1a1f2e',
      color: '#e2e8f0'
    });
    return;
  }
  
  const dataURL = sigCanvas.toDataURL('image/png');
  const base64 = dataURL.split(',')[1];
  
  closeSignatureModal();
  executeSubmitCart(sigMode, base64);
}
</script>
