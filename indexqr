    callGAS('getLoginUsers', [], users => { if (users && users.length) { allData.users = users; populateUsers(users); } }, () => {});
  }, e => {
    btn.textContent = 'ส่งคำขอสมัคร'; btn.disabled = false;
    if (e === 'demo mode') {
      document.getElementById('regSuccessMsg').textContent = `[Demo] ส่งคำขอของ "${name}" เรียบร้อย!`;
      err.style.display = 'none'; showRegStep(3);
    } else {
      err.textContent = 'เกิดข้อผิดพลาด: ' + e; err.style.display = 'block';
    }
  });
}

