function regNumDel() {
  regPin = regPin.slice(0, -1); updateRegPinDots();
  document.getElementById('regSubmitBtn').disabled = true;
  document.getElementById('regPinHint').textContent = 'กรุณากรอก PIN 4 หลัก';
}

function updateRegPinDots() {
  for (let i = 0; i < PIN_LEN; i++) {
    document.getElementById('rd' + i).classList.toggle('filled', i < regPin.length);
  }
}

function submitRegister() {
  const name = document.getElementById('regName').value.trim();
  const dept = document.getElementById('regDept').value.trim();
  const pin  = regPin;
  const err  = document.getElementById('regError');
  if (!name || pin.length < PIN_LEN) return;
  const btn = document.getElementById('regSubmitBtn');
  btn.disabled = true; btn.textContent = 'กำลังส่ง...';
  callGAS('webRegisterUser', [{ name, dept, pin }], res => {
    btn.textContent = 'ส่งคำขอสมัคร';
    if (res && res.success === false) {
      err.textContent = res.error || 'เกิดข้อผิดพลาด'; err.style.display = 'block'; btn.disabled = false; return;
    }
    document.getElementById('regSuccessMsg').textContent = `ส่งคำขอของ "${name}" เรียบร้อย!`;
    err.style.display = 'none'; showRegStep(3);
