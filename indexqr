/* ══ UPLOAD IMAGE IN RECEIVE CART ══ */
function uploadReceiveItemImg(inputEl, idx) {
  const file = inputEl.files[0];
  if (!file) return;
  inputEl.value = '';
  if (file.size > 5 * 1024 * 1024) { showToast('ไฟล์ใหญ่เกิน 5MB', 'error'); return; }
  showToast('กำลังอัปโหลดรูป...', 'info');
  const reader = new FileReader();
  reader.onload = function(e) {
    const base64   = e.target.result.split(',')[1];
    const mimeType = file.type || 'image/jpeg';
    const item     = receiveCart[idx];
    if (!item) return;
    const payload = { code: item.code, type: 'item', base64: base64, mimeType: mimeType, userName: me.name, userId: me.uid };
    callGAS('webSaveItemImage', [payload], function(res) {
      if (res && res.success) {
        receiveCart[idx].imageUrl = res.imageUrl;
        receiveCart[idx]._newImg  = true;
        // อัปเดต allData ด้วย
        var arr = [].concat(allData.items || [], allData.tools || []);
        var found = arr.find(function(i) { return i.code === item.code; });
        if (found) found.imageUrl = res.imageUrl;
        renderReceiveCart();
        showToast('อัปโหลดรูปสำเร็จ ✓', 'success');
      } else {
        showToast('อัปโหลดล้มเหลว: ' + ((res && res.error) || 'unknown'), 'error');
      }
    }, function(err) {
      showToast('เกิดข้อผิดพลาด: ' + err, 'error');
    });
  };
  reader.readAsDataURL(file);
}

