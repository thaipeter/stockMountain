function niUpdateCategory() { niUpdateCode(); }

function niUpdateCode() {
  const type = document.getElementById('niType')?.value || 'Items';
  const cat  = document.getElementById('niCat')?.value?.trim() || '';
  if (!cat) { const el=document.getElementById('niCode'); if(el) el.value=''; return; }
  // ใช้ค่า local ไว้ก่อน แล้วค่อย sync จาก GAS
  _niCalcCodeLocal(type, cat);
}

function _niCalcCodeLocal(type, cat) {
  const s = allData.settings || {};
  const defaultPrefix = type === 'Tools' ? (s.prefixTool || 'TL') : (s.prefixItem || 'IT');

  // Step 1: หา prefix จาก settings category mapping (format: "ชื่อหมวด:PREFIX")
  let prefix = null;
  if (s.categories && cat) {
    const parts = s.categories.split(',');
    for (let p of parts) {
      const str = p.trim();
      if (str.includes(':')) {
        const colonIdx = str.indexOf(':');
        const catName = str.substring(0, colonIdx).trim();
        const catPrefix = str.substring(colonIdx + 1).trim();
        if (catName.toLowerCase() === cat.trim().toLowerCase() && catPrefix !== '') {
          prefix = catPrefix.toUpperCase();
          break;
        }
      }
    }
  }

  // Step 2: ถ้าไม่มี mapping → เดาจาก codes ที่มีอยู่จริงในหมวดนั้น (เหมือน dashboard)
  if (!prefix && cat) {
    const allList = (allData.items || []).concat(allData.tools || []);
    const itemsInCat = allList.filter(i =>
      String(i.category || '').trim().toLowerCase() === cat.trim().toLowerCase()
    );
    if (itemsInCat.length > 0) {
      const prefixCount = {};
      itemsInCat.forEach(item => {
        const codeStr = String(item.code || '').toUpperCase().trim();
        const match = codeStr.match(/^([A-Z]+(?:-[A-Z]+)*)-\d+$/);
        if (match) {
          const p = match[1];
          prefixCount[p] = (prefixCount[p] || 0) + 1;
        }
      });
      if (Object.keys(prefixCount).length > 0) {
        prefix = Object.keys(prefixCount).sort((a, b) => prefixCount[b] - prefixCount[a])[0];
      }
    }
  }

  // Step 3: fallback default
  if (!prefix) prefix = defaultPrefix;

  // Step 4: หา max number จากทุก code ที่ขึ้นต้นด้วย prefix นี้
  const candidatePrefix = prefix.replace(/-+$/, '') + '-';
  const allList = (allData.items || []).concat(allData.tools || []);
  const checkCodes = allList.map(i => String(i.code || '').toUpperCase());

  let maxNum = 0;
  let maxLen = 3;
  checkCodes.forEach(codeStr => {
    if (!codeStr.startsWith(candidatePrefix)) return;
    const suffix = codeStr.slice(candidatePrefix.length);
    if (!/^\d+$/.test(suffix)) return;
    const num = parseInt(suffix, 10);
    if (!isNaN(num)) {
      maxNum = Math.max(maxNum, num);
      maxLen = Math.max(maxLen, suffix.length);
    }
  });

  const localCode = `${candidatePrefix}${String(maxNum + 1).padStart(maxLen, '0')}`;
  const el = document.getElementById('niCode');
  if (el) el.value = localCode;
  // sync จาก GAS เพื่อความแม่นยำสุด
  _niSyncCodeFromGAS(prefix, el);
}

function _niSyncCodeFromGAS(prefix, el) {
  callGAS('webGetNextCode', [{ prefix }], function(res) {
    if (res && res.success && el) {
      el.value = res.nextCode;
    }
  }, null);
}

