<script>const __GAS_URL__ = 'https://script.google.com/macros/s/AKfycbyHljTeKi0DuuseQE6QnTNnSs1ECfMYJyxSmvQ3OsE0vLo6zCwP0yKXhGL4F9lMUodn_Q/exec';</script>
<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
<script>
/* ══ STATE ══ */
let allData = {};
let me = { uid: null, name: '', role: 'user', photoUrl: null };
let withdrawCart = [];
let borrowCart   = [];
let receiveCart  = [];
let pinBuffer    = '';
let failedAttemptsMap = {};
let scannerStream = null, scanInterval = null, scanTarget = 'withdraw';
const PIN_LEN = 4;

/* ══ ROLE CONFIG ══ */
const ROLE_CONFIG = {
  admin: { icon: '👑', label: 'ผู้ดูแลระบบ', badgeClass: 'admin', badgeText: 'Admin' },
  staff: { icon: '👷', label: 'พนักงาน', badgeClass: 'staff', badgeText: 'Staff' },
  user:  { icon: '🧑‍💼', label: 'ผู้ใช้งาน', badgeClass: 'user', badgeText: 'User' },
  qr:    { icon: '🔧', label: 'QR User', badgeClass: 'qr', badgeText: 'QR' },
};

/* ══ INIT ══ */
window.addEventListener('DOMContentLoaded', () => {
  show('loadingScreen');
  callGAS('getInventoryData', [], data => {
    allData = data || {};
    applyBrandingToLoginScreen(allData.settings || {});
    hide('loadingScreen');
    show('loginScreen'); document.getElementById('appWrap').classList.remove('visible');
    populateUsers(allData.users || []);
    startUserPoll();
  }, () => {
    allData = demoData();
    hide('loadingScreen');
    show('loginScreen'); document.getElementById('appWrap').classList.remove('visible');
    populateUsers(allData.users || []);
  });
});

function applyBrandingToLoginScreen(settings) {
  try {
    const imgEl = document.getElementById('loginLogoImg');
    const emojiEl = document.getElementById('loginLogoEmoji');
    if (settings.sysLogo) {
      imgEl.src = getProxyImgUrl(settings.sysLogo) || settings.sysLogo;
      imgEl.onload = () => { imgEl.style.display = 'block'; emojiEl.style.display = 'none'; };
      imgEl.onerror = () => { imgEl.style.display = 'none'; emojiEl.style.display = 'block'; };
    }
    if (settings.sysName) {
      const titleEl = document.getElementById('loginTitleText');
      if (titleEl) titleEl.textContent = settings.sysName;
    }
  } catch (e) { /* ไม่ให้ error ตรงนี้บล็อกการเข้าสู่ระบบ */ }
}

function startUserPoll() {
  setInterval(() => {
    const pinSection = document.getElementById('pinSection');
    const searchInput = document.getElementById('loginSearch');
    if (pinSection && pinSection.style.display !== 'none') return;
    const uid = document.getElementById('loginUid').value;
    if (uid || (searchInput && document.activeElement === searchInput)) return;
    callGAS('getLoginUsers', [], users => {
      if (!users || !users.length) return;
      allData.users = users;
      // sync photoUrl ของ user ที่ login อยู่
      if (me.uid) {
        const u = users.find(x => x.userId === me.uid);
        if (u && u.photoUrl && u.photoUrl !== me.photoUrl) {
          me.photoUrl = u.photoUrl;
          const rc = ROLE_CONFIG[me.role] || ROLE_CONFIG.user;
          _setAvatarEl(document.getElementById('userAvatarImg'), document.getElementById('userAvatarIcon'), rc.icon, me.photoUrl);
        }
      }
      const uid2 = document.getElementById('loginUid').value;
      if (uid2) return;
      populateUsers(users);
    }, () => {});
  }, 10000);
}

/* ══ LOGIN ══ */
let _allUsers = [];

function populateUsers(users) {
  _allUsers = users || [];
  renderUserDropdown('');
}

function renderUserDropdown(query) {
  const dd = document.getElementById('loginDropdown');
  const q = query.trim().toLowerCase();
  const filtered = q
    ? _allUsers.filter(u => u.name.toLowerCase().includes(q))
    : _allUsers;
  if (!filtered.length) {
    dd.innerHTML = '<div style="padding:12px;text-align:center;color:var(--text3);font-size:13px">ไม่พบชื่อที่ค้นหา</div>';
    return;
  }
  dd.innerHTML = filtered.map(u => {
    const rc = ROLE_CONFIG[u.role] || ROLE_CONFIG.user;
    return `<div class="user-dropdown-item" onclick="selectUser('${u.userId}','${u.name.replace(/'/g,"\\'")}','${u.role}')"
      style="display:flex;align-items:center;gap:10px;padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);transition:background .1s"
      onmouseenter="this.style.background='var(--surface)'" onmouseleave="this.style.background=''">
      <span style="font-size:18px">${rc.icon}</span>
      <span style="font-size:14px;color:var(--text);flex:1">${u.name}</span>
      <span style="font-size:10px;padding:2px 7px;border-radius:999px;font-weight:700;background:var(--surface);border:1px solid var(--border2);color:var(--text2)">${rc.badgeText}</span>
    </div>`;
  }).join('');
}

function onLoginSearchInput(val) {
  document.getElementById('loginUid').value = '';
  document.getElementById('pinSection').style.display = 'none';
  document.getElementById('roleIndicator').classList.remove('show');
  document.getElementById('loginError').style.display = 'none';
  renderUserDropdown(val);
  showUserDropdown();
}

function showUserDropdown() {
  const dd = document.getElementById('loginDropdown');
  renderUserDropdown(document.getElementById('loginSearch').value);
  dd.style.display = 'block';
}

function hideUserDropdown() {
  setTimeout(() => { document.getElementById('loginDropdown').style.display = 'none'; }, 180);
}

function selectUser(uid, name, role) {
  document.getElementById('loginUid').value = uid;
  document.getElementById('loginSearch').value = name;
  document.getElementById('loginDropdown').style.display = 'none';
  onUserSelected();
}

document.addEventListener('click', e => {
  const wrap = document.getElementById('loginSearch')?.closest('.login-field');
  if (wrap && !wrap.contains(e.target)) {
    document.getElementById('loginDropdown').style.display = 'none';
  }
});



function onUserSelected() {
  const uid = document.getElementById('loginUid').value;
  clearPin();
  document.getElementById('pinSection').style.display = uid ? 'block' : 'none';
  document.getElementById('loginError').style.display = 'none';

  // แสดง role indicator
  const indicator = document.getElementById('roleIndicator');
  if (uid) {
    const u  = (allData.users || []).find(x => x.userId === uid);
    const rc = u ? (ROLE_CONFIG[u.role] || ROLE_CONFIG.user) : ROLE_CONFIG.user;
    document.getElementById('roleIcon').textContent = rc.icon;
    document.getElementById('roleName').textContent = u ? u.name : '';
    const badge = document.getElementById('roleBadge');
    badge.textContent  = rc.badgeText;
    badge.className    = 'sri-role-badge ' + rc.badgeClass;
    indicator.classList.add('show');
  } else {
    indicator.classList.remove('show');
  }
}

function numPress(n) {
  if (pinBuffer.length >= PIN_LEN) return;
  pinBuffer += n;
  updatePinDots();
  if (pinBuffer.length === PIN_LEN) {
    document.getElementById('loginBtn').disabled = false;
    setTimeout(doLogin, 200);
  }
}

function numDel() {
  pinBuffer = pinBuffer.slice(0, -1);
  document.getElementById('loginBtn').disabled = true;
  updatePinDots();
  document.getElementById('loginError').style.display = 'none';
}

function updatePinDots() {
  for (let i = 0; i < PIN_LEN; i++) {
    document.getElementById('d' + i).classList.toggle('filled', i < pinBuffer.length);
  }
}

function clearPin() {
  pinBuffer = '';
  updatePinDots();
  document.getElementById('loginBtn').disabled = true;
}

function doLogin() {
  const uid = document.getElementById('loginUid').value;
  const pin = pinBuffer;
  if (!uid || pin.length < PIN_LEN) return;
  const btn = document.getElementById('loginBtn');
  btn.disabled = true; btn.textContent = 'กำลังตรวจสอบ...';
  
  const isDemo = !GAS_URL && typeof google === 'undefined';
  if (isDemo) {
    btn.textContent = 'เข้าสู่ระบบ';
    if (pin === '1234' || pin === 'admin') {
      failedAttemptsMap[uid] = 0;
      loginSuccess(uid);
    } else {
      clearPin();
      document.getElementById('loginError').style.display = 'block';
    }
    return;
  }

  callGAS('webVerifyUserPin', [uid, pin], isValid => {
    btn.textContent = 'เข้าสู่ระบบ';
    if (isValid) {
      failedAttemptsMap[uid] = 0;
      loginSuccess(uid);
    }
    else { 
      clearPin(); 
      document.getElementById('loginError').style.display = 'block'; 
      failedAttemptsMap[uid] = (failedAttemptsMap[uid] || 0) + 1;
      if (failedAttemptsMap[uid] >= 3) {
        callGAS('webReportFailedLoginAttempt', [uid, failedAttemptsMap[uid]], () => {});
      }
    }
  }, () => {
