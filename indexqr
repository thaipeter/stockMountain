/* ══ CART ══ */
function addToCart(code, mode) {
  const item = getAllItems().find(i => i.code === code);
  if (!item) return;
  if (item.stock <= 0 && mode !== 'borrow') { showToast('สินค้าหมดสต็อก', 'error'); return; }
  const cart  = mode === 'withdraw' ? withdrawCart : borrowCart;
  const exist = cart.find(c => c.code === code);
  if (exist) {
    if (mode !== 'borrow' && exist.qty >= item.stock) { showToast('สต็อกไม่พอ', 'error'); return; }
    exist.qty++;
  } else {
    cart.push({ code: item.code, name: item.name, qty: 1, unit: item.unit, stock: item.stock, imageUrl: item.imageUrl || '' });
  }
  showToast(esc(item.name) + ' +1', 'success');
  updateCartBar(mode);
  const labelEl = document.getElementById(mode === 'withdraw' ? 'wActiveCat' : 'bActiveCat');
  const activeCat = labelEl ? labelEl.textContent : '__all__';
  const searchEl  = document.getElementById(mode === 'withdraw' ? 'withdrawSearch' : 'borrowSearch');
  const kw = searchEl ? searchEl.value.toLowerCase().trim() : '';
  renderList(mode, kw, activeCat.startsWith('"') ? '__all__' : activeCat || '__all__');
}

function updateCartBar(mode) {
  if (mode === 'withdraw') {
    const n = withdrawCart.length;
    document.getElementById('wCartCount').textContent = n;
    const btn = document.getElementById('wCartBtn');
    const bar = btn.closest('.cart-bar');
    btn.disabled = n === 0;
    btn.innerHTML = n > 0
      ? `<i class="fas fa-shopping-basket"></i> ตะกร้า (${n}) & ยืนยัน`
      : `<i class="fas fa-shopping-basket"></i> ดูตะกร้า & ยืนยัน`;
    if (bar) { n > 0 ? bar.classList.add('active') : bar.classList.remove('active'); }
  } else {
    const n = borrowCart.length;
    document.getElementById('bCartCount').textContent = n;
    const bBtn = document.getElementById('bCartBtn');
    bBtn.disabled = n === 0;
    const bBar = bBtn.closest('.cart-bar');
    if (bBar) { n > 0 ? bBar.classList.add('active') : bBar.classList.remove('active'); }
  }
}

