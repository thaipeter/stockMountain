// แปลง Google Drive URL ให้โหลดได้จากทุก origin
function _extractDriveId(url) {
  if (!url || url === '-' || url === '') return null;
  var m = url.match(/\/file\/d\/([^\/\?]+)/);
  if (!m) m = url.match(/[?&]id=([^&]+)/);
  if (!m) m = url.match(/thumbnail\?id=([^&]+)/);
  if (!m) m = url.match(/\/d\/([^\/\?]+)/);
  return m ? m[1] : null;
}

function getProxyImgUrl(url) {
  if (!url || url === '-' || url === '') return null;
  var firstUrl = url.split(',')[0].trim();
  if (!firstUrl || firstUrl === '-' || firstUrl === '') return null;
  var id = _extractDriveId(firstUrl);
  if (id) return 'https://drive.google.com/thumbnail?id=' + id + '&sz=w300';
  return firstUrl;
}

function getFullImgUrl(url) {
  if (!url || url === '-' || url === '') return null;
  var firstUrl = url.split(',')[0].trim();
  if (!firstUrl || firstUrl === '-' || firstUrl === '') return null;
  var id = _extractDriveId(firstUrl);
  if (id) return 'https://drive.google.com/thumbnail?id=' + id + '&sz=w1200';
