let regPin = '';
let regUserId = null;
let regPollTimer = null;

function openRegister() {
  regPin = '';
  document.getElementById('regName').value = '';
  document.getElementById('regDept').value = '';
  document.getElementById('regError').style.display = 'none';
  updateRegPinDots();
  showRegStep(1);
  document.getElementById('registerModal').classList.add('open');
}

function closeRegister() {
  document.getElementById('registerModal').classList.remove('open');
  regPin = '';
  stopRegPoll();
}
function showRegStep(n) {
  [1,2,3].forEach(i => { document.getElementById('regStep'+i).classList.toggle('active',i===n); });
  if (n === 1) resetRegSuccessUI();
}

function resetRegSuccessUI() {
  document.getElementById('regSpinner').style.display = 'block';
  document.getElementById('regApprovedIcon').classList.remove('show');
  document.getElementById('regSuccessMsg').classList.remove('approved');
  document.getElementById('regSuccessSub').classList.remove('approved');
}

function startRegPoll(userId) {
  regUserId = userId;
  stopRegPoll();
  regPollTimer = setInterval(() => {
    callGAS('webCheckRegStatus', [userId], res => {
      if (res && res.status === 'approved') {
        stopRegPoll();
        showRegApproved();
      } else if (res && res.status === 'rejected') {
        stopRegPoll();
        showRegRejected();
      }
    }, () => {});
  }, 4000);
}

function stopRegPoll() {
  if (regPollTimer) { clearInterval(regPollTimer); regPollTimer = null; }
}

function showRegApproved() {
  document.getElementById('regSpinner').style.display = 'none';
  const icon = document.getElementById('regApprovedIcon');
  icon.classList.add('show');
  const msg = document.getElementById('regSuccessMsg');
  msg.textContent = 'อนุมัติเรียบร้อยแล้ว!';
  msg.classList.add('approved');
  const sub = document.getElementById('regSuccessSub');
  sub.textContent = 'เข้าใช้งานได้เลยตอนนี้ 🎉';
  sub.classList.add('approved');
}

function showRegRejected() {
  document.getElementById('regSpinner').style.display = 'none';
  document.getElementById('regSuccessMsg').textContent = 'คำขอไม่ได้รับการอนุมัติ';
  document.getElementById('regSuccessSub').textContent = 'กรุณาติดต่อ Admin';
}

function goRegStep2() {
  const name = document.getElementById('regName').value.trim();
  const err  = document.getElementById('regError');
  if (!name) { err.textContent = 'กรุณากรอกชื่อ-นามสกุล'; err.style.display = 'block'; return; }
  err.style.display = 'none'; regPin = '';
  updateRegPinDots();
  document.getElementById('regSubmitBtn').disabled = true;
  document.getElementById('regPinHint').textContent = 'กรุณากรอก PIN 4 หลัก';
  showRegStep(2);
}

function backRegStep1() { document.getElementById('regError').style.display = 'none'; showRegStep(1); }

function regNumPress(n) {
  if (regPin.length >= PIN_LEN) return;
  regPin += n; updateRegPinDots();
  if (regPin.length === PIN_LEN) {
    document.getElementById('regSubmitBtn').disabled = false;
    document.getElementById('regPinHint').textContent = 'PIN ครบแล้ว กด "ส่งคำขอ" ได้เลย';
