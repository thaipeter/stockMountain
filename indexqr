  document.getElementById(id).classList.add('open');
}

function closeSheet(id) { document.getElementById(id).classList.remove('open'); }
function overlayClose(e, id) { if (e.target === document.getElementById(id)) closeSheet(id); }

function removeCart(i, mode) {
  const cart = mode === 'withdraw' ? withdrawCart : borrowCart;
  cart.splice(i, 1);
  updateCartBar(mode);
  const sid = mode === 'withdraw' ? 'sheetWithdraw' : 'sheetBorrow';
  if (!cart.length) { closeSheet(sid); renderList(mode, ''); return; }
  openSheet(sid);
  renderList(mode, '');
}

function changeQty(i, mode, d) {
  const cart = mode === 'withdraw' ? withdrawCart : borrowCart;
  const item = cart[i];
  const nq   = item.qty + d;
  if (nq < 1) return;
  if (mode !== 'borrow' && nq > item.stock) { showToast('สต็อกไม่พอ', 'error'); return; }
  item.qty = nq;
  const inp = document.getElementById(`qi_${mode}_${i}`);
  if (inp) inp.value = nq;
}

function setQty(i, mode, v) {
  const cart = mode === 'withdraw' ? withdrawCart : borrowCart;
  const inp  = document.getElementById(`qi_${mode}_${i}`);
  let n      = parseInt(v);
  if (!n || n < 1) {
    n = 1;
    cart[i].qty = 1;
    if (inp) inp.value = 1;
    showToast('จำนวนขั้นต่ำคือ 1', 'error');
    return;
  }
  if (mode !== 'borrow' && n > cart[i].stock) {
    n = cart[i].stock;
    cart[i].qty = n;
    if (inp) inp.value = n;
    showToast(`เบิกได้สูงสุด ${n} ${cart[i].unit}`, 'error');
    return;
  }
  cart[i].qty = n;
}

