function closeChangePin() { document.getElementById('changePinModal').classList.remove('open'); cpOldPin = ''; cpNewPin = ''; }
function showCpStep(n) { [1,2,3].forEach(i => document.getElementById('cpStep'+i).classList.toggle('active', i===n)); }

function cpPress(mode, n) {
  if (mode === 'old') {
    if (cpOldPin.length >= PIN_LEN) return;
    cpOldPin += n;
    updateCpDots('old');
    document.getElementById('cpVerifyBtn').disabled = cpOldPin.length < PIN_LEN;
  } else {
    if (cpNewPin.length >= PIN_LEN) return;
    cpNewPin += n;
    updateCpDots('new');
    const full = cpNewPin.length === PIN_LEN;
    document.getElementById('cpSaveBtn').disabled = !full;
    document.getElementById('cpNewHint').textContent = full ? 'PIN ครบแล้ว กด "บันทึก PIN ใหม่"' : 'กรอก PIN ใหม่ 4 หลัก';
  }
}

function cpDel(mode) {
  if (mode === 'old') {
    cpOldPin = cpOldPin.slice(0,-1);
    updateCpDots('old');
    document.getElementById('cpVerifyBtn').disabled = cpOldPin.length < PIN_LEN;
  } else {
    cpNewPin = cpNewPin.slice(0,-1);
    updateCpDots('new');
    document.getElementById('cpSaveBtn').disabled = true;
    document.getElementById('cpNewHint').textContent = 'กรอก PIN ใหม่ 4 หลัก';
  }
}

function updateCpDots(mode) {
  const pin = mode === 'old' ? cpOldPin : cpNewPin;
  const prefix = mode === 'old' ? 'cop' : 'cnp';
  for (let i = 0; i < PIN_LEN; i++) {
    document.getElementById(prefix+i).classList.toggle('filled', i < pin.length);
  }
}

function cpVerifyOld() {
  const btn = document.getElementById('cpVerifyBtn');
  const err = document.getElementById('cpError');
  btn.disabled = true; btn.textContent = 'กำลังตรวจสอบ...';
  err.style.display = 'none';
  callGAS('webVerifyUserPin', [me.uid, cpOldPin], isValid => {
    btn.textContent = 'ยืนยัน PIN เก่า →';
    if (isValid) {
      cpNewPin = '';
      updateCpDots('new');
      document.getElementById('cpSaveBtn').disabled = true;
      document.getElementById('cpNewHint').textContent = 'กรอก PIN ใหม่ 4 หลัก';
      document.getElementById('cpSubTitle').textContent = 'ตั้ง PIN ใหม่ของคุณ';
      err.style.display = 'none';
      showCpStep(2);
    } else {
      btn.disabled = false;
