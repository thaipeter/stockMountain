<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ทำรายการ</title>
<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
:root {
  --bg:#0f0f0f; --surface:#161616; --surface2:#1e1e1e;
  --border:#2a2a2a; --border2:#333;
  --text:#c0c0c0; --text2:#666; --text3:#444;
  --amber:#e8a020; --amber-dim:rgba(232,160,32,.12);
  --red:#ef5350;   --red-dim:rgba(239,83,80,.12);
  --green:#66bb6a; --green-dim:rgba(102,187,106,.12);
  --blue:#42a5f5;  --blue-dim:rgba(66,165,245,.12);
  --purple:#ab47bc; --purple-dim:rgba(171,71,188,.12);
  --radius:10px; --radius-sm:6px;
  --tab-h:52px; --bar-h:56px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;margin:0;background:var(--bg);font-family:'Prompt',sans-serif;color:var(--text);overscroll-behavior:none}
body{display:flex;flex-direction:column}
#appWrap{display:none;flex-direction:column;height:100vh;height:100dvh;width:100%;max-width:100%;overflow:hidden;position:relative}
#appWrap.visible{display:flex;animation:pageFadeIn .35s ease}
@keyframes pageFadeIn{from{opacity:0}to{opacity:1}}
*:focus{outline:none}

/* ── Loading ── */
.loading-screen{
  position:fixed;inset:0;background:var(--bg);z-index:999;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;
}
.loading-screen.hidden{display:none}
.spinner{width:36px;height:36px;border:3px solid var(--border2);border-top-color:var(--amber);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-icon{font-size:46px;color:var(--amber);animation:loadingGlow 1.6s ease-in-out infinite}
@keyframes loadingGlow{
  0%,100%{transform:translateY(0) scale(1);filter:drop-shadow(0 0 6px rgba(232,160,32,.5));opacity:.8}
  50%{transform:translateY(-8px) scale(1.1);filter:drop-shadow(0 0 22px rgba(232,160,32,.9));opacity:1}
}
.loading-text{font-size:13px;color:var(--text2)}

/* ── Login Screen ── */
.login-screen{
  position:fixed;inset:0;background:var(--bg);z-index:998;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:24px;
}
.login-screen.hidden{display:none}
.login-logo{font-size:40px;margin-bottom:8px}
.login-title{font-size:18px;font-weight:700;color:var(--text);letter-spacing:1px;margin-bottom:4px}
.login-sub{font-size:12px;color:var(--text2);margin-bottom:32px}
.login-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:24px;width:100%;max-width:360px}
.login-field{margin-bottom:16px}
.login-label{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text2);margin-bottom:6px}

/* role badges legend */
.role-legend{display:flex;gap:12px;justify-content:center;margin-bottom:14px;flex-wrap:wrap}
.role-badge{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text2)}
.role-badge .rb-icon{font-size:14px}
.role-badge .rb-label{font-size:10px;color:var(--text3)}

.login-select,.login-input{
  width:100%;background:var(--bg);border:1px solid var(--border2);
  border-radius:var(--radius-sm);color:var(--text);
  font-family:'Prompt',sans-serif;font-size:14px;padding:12px;outline:none;
  transition:border-color .2s;appearance:none;-webkit-appearance:none;
}
.login-select:focus,.login-input:focus{border-color:var(--amber)}
.login-select option{background:var(--surface2)}

/* selected user role indicator */
.selected-role-indicator{
  display:none;align-items:center;gap:8px;
  background:var(--surface2);border:1px solid var(--border2);
  border-radius:var(--radius-sm);padding:8px 12px;margin-top:8px;
}
.selected-role-indicator.show{display:flex}
.sri-icon{font-size:20px}
.sri-info{flex:1}
.sri-name{font-size:13px;font-weight:600;color:var(--text)}
.sri-role{font-size:11px;color:var(--text2)}
.sri-role-badge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:999px}
.sri-role-badge.admin{background:var(--amber-dim);color:var(--amber);border:1px solid var(--amber)}
.sri-role-badge.user{background:var(--green-dim);color:var(--green);border:1px solid var(--green)}
.sri-role-badge.qr{background:var(--blue-dim);color:var(--blue);border:1px solid var(--blue)}
.sri-role-badge.staff{background:var(--purple-dim);color:var(--purple);border:1px solid var(--purple)}

.pin-display{display:flex;gap:10px;justify-content:center;margin-bottom:20px}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid var(--border2);background:transparent;transition:all .15s}
.pin-dot.filled{background:var(--amber);border-color:var(--amber)}
.numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px}
.num-btn{
  background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);
  color:var(--text);font-family:'Prompt',sans-serif;font-size:20px;font-weight:500;
  padding:16px;cursor:pointer;transition:all .1s;text-align:center;
  -webkit-user-select:none;user-select:none;
}
.num-btn:active{background:var(--amber-dim);border-color:var(--amber);transform:scale(.95)}
.num-btn.del{font-size:16px;color:var(--text2)}
.num-btn.empty{background:transparent;border:none;cursor:default}
.login-btn{
  width:100%;border:none;border-radius:var(--radius);
  background:var(--amber);color:#000;
  font-family:'Prompt',sans-serif;font-size:14px;font-weight:700;
  padding:13px;cursor:pointer;transition:opacity .2s;letter-spacing:.5px;
}
.login-btn:disabled{opacity:.4;cursor:not-allowed}
.login-error{font-size:12px;color:var(--red);text-align:center;margin-top:8px;display:none}

/* ── Register link ── */
.register-link{margin-top:20px;text-align:center;font-size:12px;color:var(--text2)}
.register-link a{color:var(--amber);text-decoration:none;font-weight:600;cursor:pointer}

/* ── Register Modal ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:999;display:none;align-items:flex-end;justify-content:center}
.modal-overlay.open{display:flex}
.modal-box{background:var(--surface);border:1px solid var(--border2);border-radius:20px 20px 0 0;width:100%;max-width:480px;padding:24px 24px 32px;animation:slideUp .25s ease}
.modal-handle{width:36px;height:4px;background:var(--border2);border-radius:2px;margin:0 auto 16px}
.modal-title{font-size:16px;font-weight:700;color:var(--text);margin-bottom:4px}
.modal-sub{font-size:12px;color:var(--text2);margin-bottom:20px}
.reg-field{margin-bottom:14px}
.reg-label{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text2);margin-bottom:6px}
.reg-input{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:var(--radius-sm);color:var(--text);font-family:'Prompt',sans-serif;font-size:14px;padding:12px;outline:none;transition:border-color .2s}
.reg-input:focus{border-color:var(--amber)}
.reg-pin-row{display:flex;gap:10px;justify-content:center;margin-bottom:6px}
.reg-pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid var(--border2);background:transparent;transition:all .15s}
.reg-pin-dot.filled{background:var(--amber);border-color:var(--amber)}
.reg-numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px}
.reg-num-btn{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-family:'Prompt',sans-serif;font-size:18px;font-weight:500;padding:14px;cursor:pointer;transition:all .1s;text-align:center;-webkit-user-select:none;user-select:none}
.reg-num-btn:active{background:var(--amber-dim);border-color:var(--amber);transform:scale(.95)}
.reg-num-btn.del{font-size:14px;color:var(--text2)}
.reg-num-btn.empty{background:transparent;border:none;cursor:default}
.reg-hint{font-size:11px;color:var(--text3);text-align:center;margin-bottom:12px}
.reg-btn-row{display:flex;gap:8px}
.reg-cancel-btn{flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text2);font-family:'Prompt',sans-serif;font-size:13px;font-weight:600;padding:12px;cursor:pointer}
.reg-submit-btn{flex:2;background:var(--amber);border:none;border-radius:var(--radius-sm);color:#000;font-family:'Prompt',sans-serif;font-size:13px;font-weight:700;padding:12px;cursor:pointer;transition:opacity .2s}
.reg-submit-btn:disabled{opacity:.4;cursor:not-allowed}
.reg-error{font-size:12px;color:var(--red);text-align:center;margin-bottom:10px;display:none}
.reg-step{display:none}
.reg-step.active{display:block}
.reg-success{text-align:center;padding:16px 0}
.reg-success-icon{font-size:48px;margin-bottom:12px}
.reg-pending-spinner{width:48px;height:48px;margin:0 auto 12px;border:4px solid rgba(232,160,32,.2);border-top-color:var(--amber);border-radius:50%;animation:spin .8s linear infinite}
.reg-pending-spinner.approved{display:none}
.reg-success-icon.approved{display:none;font-size:48px;margin-bottom:12px;animation:popIn .35s ease}
.reg-success-icon.approved.show{display:block}
@keyframes popIn{0%{transform:scale(.3);opacity:0}60%{transform:scale(1.15)}100%{transform:scale(1);opacity:1}}
.reg-success-msg{font-size:14px;color:var(--text);margin-bottom:4px;font-weight:600}
.reg-success-msg.approved{color:var(--green)}
.reg-success-sub{font-size:12px;color:var(--text2)}
.reg-success-sub.approved{color:var(--green)}

/* ── Top bar ── */
.topbar{height:var(--bar-h);background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 16px;flex-shrink:0}
.topbar-left{display:flex;align-items:center;gap:10px}
.topbar-title{font-size:14px;font-weight:600;color:var(--text)}
.topbar-sub{font-size:11px;color:var(--text2)}
.user-avatar{width:38px;height:38px;border-radius:50%;background:var(--amber-dim);border:1px solid var(--amber);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--amber);cursor:pointer;overflow:hidden}
.user-name{font-size:11px;color:var(--text2);max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* ── Tabs ── */
.tabs{height:var(--tab-h);background:var(--surface);border-bottom:1px solid var(--border);display:flex;flex-shrink:0}
.tab-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;background:none;border:none;border-bottom:2px solid transparent;font-family:'Prompt',sans-serif;font-size:12px;font-weight:600;letter-spacing:.5px;color:var(--text3);cursor:pointer;transition:all .2s}
.tab-btn i{font-size:14px}
.tab-btn.active-withdraw{color:var(--red);border-bottom-color:var(--red);background:var(--red-dim)}
.tab-btn.active-borrow{color:var(--blue);border-bottom-color:var(--blue);background:var(--blue-dim)}
.tab-btn.active-receive{color:var(--green);border-bottom-color:var(--green);background:var(--green-dim)}
.tab-btn.active-newitem{color:#8b5cf6;border-bottom-color:#8b5cf6;background:rgba(139,92,246,.12)}
.tab-btn.active-stocktake{color:#f59e0b;border-bottom-color:#f59e0b;background:rgba(245,158,11,.12)}

/* ── Content ── */
.content{flex:1;display:none;flex-direction:column;min-height:0;overflow:hidden;position:relative}
.content.active{display:flex}

/* ── Search ── */
.search-area{padding:12px 12px 8px;flex-shrink:0}
.search-wrap{display:flex;gap:8px}
.search-input-wrap{flex:1;position:relative}
.search-input-wrap i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:13px;pointer-events:none}
.search-input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'Prompt',sans-serif;font-size:14px;padding:10px 12px 10px 34px;outline:none;transition:border-color .2s}
.search-input:focus{border-color:var(--amber)}
.scan-btn{background:var(--amber);border:none;border-radius:var(--radius-sm);color:#000;padding:0 16px;font-size:16px;font-weight:700;cursor:pointer;flex-shrink:0;display:flex;align-items:center;gap:6px;transition:all .2s;white-space:nowrap;font-family:'Prompt',sans-serif}
.scan-btn:active{opacity:.8;transform:scale(.96)}

/* ── Item list ── */
.item-list{flex:1;overflow-y:auto;padding:0 12px 8px;min-height:0}.item-list.hidden{display:none!important}
.item-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;margin-bottom:8px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:12px;-webkit-user-select:none;user-select:none}
.item-card:active{transform:scale(.98)}
.item-card.in-cart{border-color:var(--green);background:var(--green-dim)}
.item-icon{width:38px;height:38px;border-radius:var(--radius-sm);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:16px;background:var(--surface);border:1px solid var(--border2);overflow:hidden}
.item-icon img{width:100%;height:100%;object-fit:cover;border-radius:var(--radius-sm)}
.item-info{flex:1;min-width:0}
.item-name{font-size:13px;font-weight:500;color:var(--text);margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.item-code{font-size:11px;color:var(--text2);font-family:monospace}
.in-cart-badge{font-size:10px;font-weight:600;color:var(--green);margin-top:2px}
.item-stock{text-align:right;flex-shrink:0}
.stock-num{font-size:15px;font-weight:700}
.stock-unit{font-size:10px;color:var(--text2)}
.stock-ok{color:var(--green)} .stock-low{color:#ff9800} .stock-zero{color:var(--red)}
.empty-state{text-align:center;padding:40px 20px;color:var(--text3)}
.empty-state i{font-size:40px;margin-bottom:12px;display:block}
.empty-state p{font-size:13px}

/* ── Cart bar ── */
.cart-bar{background:var(--surface);border-top:1px solid var(--border2);padding:10px 12px;flex-shrink:0;display:none!important;gap:8px;align-items:center}.cart-bar.active{display:flex!important}
.cart-count-info{flex:1}
.cart-count{font-size:12px;color:var(--text2)}
.cart-count span{color:var(--amber);font-weight:700}
.cart-btn{flex:2;border:none;border-radius:var(--radius-sm);font-family:'Prompt',sans-serif;font-size:13px;font-weight:700;padding:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px}
.cart-btn:disabled{background:var(--surface2);color:var(--text3);cursor:not-allowed}
.cart-btn.withdraw{background:var(--red);color:#fff}
.cart-btn.borrow{background:var(--blue);color:#fff}
.cart-btn.receive{background:var(--green);color:#fff}

/* ── Sheet ── */
.sheet-overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:100;display:none;align-items:flex-end}
.sheet-overlay.open{display:flex}
.sheet{background:var(--surface);width:100%;border-radius:20px 20px 0 0;border-top:1px solid var(--border2);max-height:92vh;display:flex;flex-direction:column;animation:slideUp .25s ease}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.sheet-handle{width:36px;height:4px;background:var(--border2);border-radius:2px;margin:10px auto 4px;flex-shrink:0}
.sheet-header{padding:8px 16px 12px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:space-between}
.sheet-title{font-size:15px;font-weight:600}
.sheet-close{background:none;border:none;color:var(--text2);font-size:20px;cursor:pointer;padding:4px}
.sheet-body{flex:1;overflow-y:auto;padding:12px 16px}
.sheet-footer{padding:12px 16px;border-top:1px solid var(--border);flex-shrink:0}

/* ── Cart items ── */
.cart-item{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;margin-bottom:8px}
.cart-item-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:8px}
.cart-item-name{font-size:13px;font-weight:500;color:var(--text)}
.cart-item-code{font-size:11px;color:var(--text2);font-family:monospace;margin-top:2px}
.cart-remove{background:none;border:none;color:var(--red);font-size:16px;cursor:pointer;padding:2px 6px;flex-shrink:0}
.qty-row{display:flex;align-items:center;gap:8px}
.qty-btn{width:36px;height:36px;border-radius:var(--radius-sm);background:var(--surface);border:1px solid var(--border2);color:var(--text);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.qty-btn:active{background:var(--border2)}
.qty-input{flex:0 0 70px;background:var(--bg);border:1px solid var(--border2);border-radius:var(--radius-sm);color:var(--amber);font-family:'Prompt',sans-serif;font-size:18px;font-weight:700;text-align:center;padding:6px;outline:none}
.qty-unit{font-size:11px;color:var(--text2);flex-shrink:0}

/* ── Form fields ── */
.field{margin-bottom:12px}
.field-label{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text2);margin-bottom:6px}
.field-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'Prompt',sans-serif;font-size:14px;padding:10px 12px;outline:none;transition:border-color .2s}
.field-input:focus{border-color:var(--amber)}
.remark-quick{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px}
.remark-chip{background:var(--surface2);border:1px solid var(--border2);border-radius:999px;color:var(--text2);font-size:11px;padding:4px 10px;cursor:pointer;transition:all .15s}
.remark-chip:active{background:var(--amber-dim);border-color:var(--amber);color:var(--amber)}

/* ── Submit btn ── */
.submit-btn{width:100%;border:none;border-radius:var(--radius);font-family:'Prompt',sans-serif;font-size:15px;font-weight:700;padding:14px;cursor:pointer;transition:opacity .2s;letter-spacing:.5px}
.submit-btn:disabled{opacity:.4;cursor:not-allowed}
.submit-withdraw{background:var(--red);color:#fff}
.submit-borrow{background:var(--blue);color:#fff}
.submit-receive{background:var(--green);color:#000}

/* ── Borrow sub tabs ── */
.borrow-tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0;margin:0 12px}
.borrow-tab{flex:1;padding:10px;font-family:'Prompt',sans-serif;font-size:12px;font-weight:600;background:none;border:none;color:var(--text3);border-bottom:2px solid transparent;cursor:pointer;transition:all .2s}
.borrow-tab.active{color:var(--blue);border-bottom-color:var(--blue)}
.borrow-section{display:none;flex:1;flex-direction:column;overflow:hidden;min-height:0}
.borrow-section.active{display:flex}

/* ── Return cards ── */
.return-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px}
.return-info{flex:1;min-width:0}
.return-name{font-size:13px;font-weight:500;color:var(--text);margin-bottom:2px}
.return-meta{font-size:11px;color:var(--text2)}
.return-btn{background:var(--green-dim);border:1px solid var(--green);border-radius:var(--radius-sm);color:var(--green);font-family:'Prompt',sans-serif;font-size:11px;font-weight:600;padding:6px 12px;cursor:pointer;white-space:nowrap}

/* ── New item tab ── */
.newitem-form{padding:12px 16px;flex:1;overflow-y:auto}
.ni-section-title{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text3);margin:16px 0 10px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.ni-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px 14px 10px;margin-bottom:10px;position:relative}
.ni-card-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.ni-row{display:flex;gap:8px;margin-bottom:8px}
.ni-field{flex:1;display:flex;flex-direction:column;gap:4px}
.ni-label{font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text3)}
.ni-input{background:var(--bg);border:1px solid var(--border2);border-radius:8px;color:var(--text);font-family:'Prompt',sans-serif;font-size:13px;padding:8px 10px;width:100%;outline:none;transition:border-color .2s}
.ni-input:focus{border-color:var(--amber)}
.ni-input[readonly]{opacity:.6;cursor:not-allowed}
/* รูปภาพ upload */
.ni-img-box{width:100%;aspect-ratio:16/9;border-radius:10px;border:2px dashed var(--border2);background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;overflow:hidden;position:relative}
.ni-img-box:hover{border-color:var(--amber);background:var(--amber-dim)}
.ni-img-box img{width:100%;height:100%;object-fit:cover;border-radius:8px}
.ni-img-box .ni-img-placeholder{display:flex;flex-direction:column;align-items:center;gap:6px;color:var(--text3);pointer-events:none}
.ni-img-box .ni-img-placeholder i{font-size:28px}
.ni-img-box .ni-img-placeholder span{font-size:11px;font-weight:600}
.ni-img-remove{position:absolute;top:6px;right:6px;background:rgba(239,68,68,.85);color:#fff;border:none;border-radius:50%;width:24px;height:24px;font-size:11px;cursor:pointer;display:none;align-items:center;justify-content:center}
.ni-img-remove.show{display:flex}
.ni-upload-bar{display:flex;gap:8px;margin-top:8px}
.ni-upload-btn{flex:1;background:var(--bg);border:1px solid var(--border2);border-radius:8px;color:var(--text2);font-family:'Prompt',sans-serif;font-size:12px;font-weight:600;padding:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .2s}
.ni-upload-btn:hover{border-color:var(--amber);color:var(--amber)}
/* item card image */
.item-img{width:40px;height:40px;object-fit:cover;border-radius:8px;border:1px solid var(--border2);flex-shrink:0}
.item-img-placeholder{width:40px;height:40px;border-radius:8px;border:1px solid var(--border);background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
/* upload img inline btn */
.upload-img-btn{display:inline-flex;align-items:center;gap:4px;background:var(--bg);border:1px solid var(--border2);border-radius:6px;color:var(--text3);font-family:'Prompt',sans-serif;font-size:11px;font-weight:600;padding:3px 8px;cursor:pointer;transition:all .2s;white-space:nowrap}
.upload-img-btn:hover{border-color:var(--amber);color:var(--amber)}
.receive-section-title{font-size:12px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin:16px 0 10px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.receive-item-row{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;margin-bottom:8px;display:flex;align-items:center;gap:10px}
.receive-item-row .item-icon{width:32px;height:32px;font-size:14px}
.add-item-btn{width:100%;background:var(--surface2);border:2px dashed var(--border2);border-radius:var(--radius);color:var(--text2);font-family:'Prompt',sans-serif;font-size:13px;padding:12px;cursor:pointer;transition:all .2s;margin-top:4px}
.add-item-btn:active{border-color:var(--green);color:var(--green)}
.receive-cart-bar{background:var(--surface);border-top:1px solid var(--border2);padding:10px 16px;flex-shrink:0;display:flex;gap:8px}
.receive-total{font-size:12px;color:var(--text2);flex:1;display:flex;align-items:center}
.receive-total span{color:var(--green);font-weight:700}

/* ── QR Scanner ── */
.scanner-overlay{position:fixed;inset:0;background:#000;z-index:200;display:none;flex-direction:column;align-items:center;justify-content:center}
.scanner-overlay.open{display:flex}
.scanner-frame{width:260px;height:260px;position:relative}
.scanner-frame video{width:100%;height:100%;object-fit:cover;border-radius:var(--radius)}
.scanner-corners{position:absolute;inset:0;pointer-events:none}
.corner{position:absolute;width:24px;height:24px;border-color:var(--amber);border-style:solid}
.corner.tl{top:0;left:0;border-width:3px 0 0 3px;border-radius:4px 0 0 0}
.corner.tr{top:0;right:0;border-width:3px 3px 0 0;border-radius:0 4px 0 0}
.corner.bl{bottom:0;left:0;border-width:0 0 3px 3px;border-radius:0 0 0 4px}
.corner.br{bottom:0;right:0;border-width:0 3px 3px 0;border-radius:0 0 4px 0}
.scanner-line{position:absolute;left:6px;right:6px;height:2px;background:var(--amber);animation:scan 2s linear infinite;opacity:.8}
@keyframes scan{0%{top:6px}100%{top:calc(100% - 8px)}}
.scanner-label{color:#fff;font-size:13px;margin-top:20px;opacity:.7}
.scanner-close{position:absolute;top:20px;right:20px;background:rgba(255,255,255,.1);border:none;color:#fff;width:40px;height:40px;border-radius:50%;font-size:20px;cursor:pointer}

/* ═══════════════════════════════════
   CATEGORY GRID — เต็ม 3 คอลัมน์
═══════════════════════════════════ */
.cat-screen{flex:1;overflow-y:auto;padding:12px;min-height:0;background:var(--bg);display:flex;flex-direction:column}
.cat-screen.hidden{display:none!important}
.cat-header{font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text3);margin-bottom:10px;padding:0 2px}

/* === 3 คอลัมน์เสมอ ไม่มี all-card span full === */
.cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;align-content:start}

.cat-card{
  background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);
  padding:14px 10px;cursor:pointer;transition:all .15s;
  display:flex;flex-direction:column;align-items:center;gap:6px;text-align:center;
  -webkit-user-select:none;user-select:none;
}
.cat-card:active{transform:scale(.96);border-color:var(--amber);background:var(--amber-dim)}
.cat-icon{font-size:26px;line-height:1}
.cat-name{font-size:12px;font-weight:600;color:var(--text);line-height:1.3}
.cat-count{font-size:10px;color:var(--text2)}

/* all-card — span full width, horizontal layout */
.cat-card.all-card{
  grid-column:1/-1;
  flex-direction:row;align-items:center;text-align:left;gap:12px;
  padding:14px 16px;border-color:var(--border2);
}
.cat-card.all-card .cat-icon{font-size:20px}
.cat-card.all-card .cat-name{font-size:13px}

/* back button row */
.back-row{display:flex;align-items:center;gap:8px;padding:10px 12px 4px;flex-shrink:0}.back-row.hidden{display:none!important}
.back-btn{background:none;border:none;color:var(--text2);font-family:'Prompt',sans-serif;font-size:12px;display:flex;align-items:center;gap:6px;cursor:pointer;padding:4px 0}
.back-btn i{font-size:13px}
.active-cat-label{font-size:12px;font-weight:600;color:var(--amber);background:var(--amber-dim);border:1px solid var(--amber);border-radius:999px;padding:3px 10px;margin-left:auto}

.tab-btn.active-mine{color:#ab47bc;border-bottom-color:#ab47bc;background:rgba(171,71,188,.12)}

/* ── Mine tab ── */
.mine-sub-tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0;margin:0 12px}
.mine-sub-tab{flex:1;padding:10px;font-family:'Prompt',sans-serif;font-size:12px;font-weight:600;background:none;border:none;color:var(--text3);border-bottom:2px solid transparent;cursor:pointer;transition:all .2s}
.mine-sub-tab.active{color:var(--purple);border-bottom-color:var(--purple)}
.mine-section{display:none;flex:1;flex-direction:column;overflow:hidden;min-height:0}
.mine-section.active{display:flex}
.mine-list{flex:1;overflow-y:auto;padding:12px}
.mine-empty{text-align:center;padding:48px 20px;color:var(--text3)}
.mine-empty i{font-size:40px;margin-bottom:12px;display:block}
.mine-empty p{font-size:13px}
.hist-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;margin-bottom:8px}
.hist-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px}
.hist-name{font-size:13px;font-weight:600;color:var(--text)}
.hist-type{font-size:10px;font-weight:700;padding:2px 8px;border-radius:999px}
.hist-type-withdraw{background:var(--red-dim);color:var(--red);border:1px solid var(--red)}
.hist-type-borrow{background:var(--blue-dim);color:var(--blue);border:1px solid var(--blue)}
.hist-meta{font-size:11px;color:var(--text2)}
.hist-remark{font-size:11px;color:var(--text3);margin-top:3px;font-style:italic}
.borrow-status-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px}
.borrow-status-card.overdue{border-color:var(--red);background:var(--red-dim)}
.bscard-icon{width:40px;height:40px;border-radius:var(--radius-sm);background:var(--surface);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.bscard-info{flex:1;min-width:0}
.bscard-name{font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bscard-meta{font-size:11px;color:var(--text2)}
.bscard-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:999px;white-space:nowrap;flex-shrink:0}
.bscard-badge-active{background:var(--blue-dim);color:var(--blue);border:1px solid var(--blue)}
.bscard-badge-overdue{background:var(--red-dim);color:var(--red);border:1px solid var(--red)}
.mine-stat-row{display:flex;gap:8px;padding:12px 12px 0;flex-shrink:0}
.mine-stat{flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 10px;text-align:center}
.mine-stat-num{font-size:22px;font-weight:700}
.mine-stat-label{font-size:10px;color:var(--text2);margin-top:2px}
.mine-refresh-btn{display:flex;align-items:center;justify-content:center;gap:6px;margin:10px 12px 4px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text2);font-family:'Prompt',sans-serif;font-size:12px;padding:8px;cursor:pointer;transition:all .2s}
.mine-refresh-btn:active{border-color:var(--purple);color:var(--purple)}

/* ── Toast ── */
.toast-wrap{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);z-index:300;pointer-events:none;display:flex;flex-direction:column;gap:6px;align-items:center}
.toast{background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius);padding:10px 16px;font-size:13px;color:var(--text);white-space:nowrap;animation:toastIn .2s ease;box-shadow:0 8px 24px rgba(0,0,0,.6);display:flex;align-items:center;gap:8px}
.toast.success{border-color:var(--green);color:var(--green)}
.toast.error{border-color:var(--red);color:var(--red)}
.toast.info{border-color:var(--amber);color:var(--amber)}
@keyframes toastIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* ═══════════════════════════════════
   RESPONSIVE
═══════════════════════════════════ */
@media (min-width: 768px) {
  body{align-items:center;background:#080808}
  .loading-screen,.login-screen{background:#080808}
  .login-card{max-width:420px}
  #appWrap{max-width:720px;box-shadow:0 0 60px rgba(0,0,0,.8)}
  .sheet-overlay{align-items:center;justify-content:center;max-width:100%}
  .sheet{border-radius:16px;max-width:600px;width:100%;max-height:80vh}
  @keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
  .modal-overlay{align-items:center;justify-content:center}
  .modal-box{border-radius:16px;max-width:480px}
  .numpad{max-width:320px;margin-left:auto;margin-right:auto}
  .num-btn{padding:20px;font-size:22px}
  .topbar{padding:0 24px}
  .search-area{padding:16px 16px 10px}
  .item-list{padding:0 16px 12px}
  .cat-screen{padding:16px}
  .item-card:hover{background:var(--surface);border-color:var(--border2);transform:none}
  .scanner-frame{width:320px;height:320px}
  .toast-wrap{bottom:32px}
  .cat-grid{grid-template-columns:repeat(4,1fr)}
}

@media (min-width: 768px) and (max-width: 1199px) {
  #appWrap{max-width:600px}
  .cat-grid{grid-template-columns:repeat(3,1fr)}
}

@media (min-width: 1200px) {
  body{justify-content:center}
  #appWrap{max-width:760px}
}

@media (max-width: 767px) {
  .cart-bar{padding-bottom:calc(10px + env(safe-area-inset-bottom))}
  .sheet-footer{padding-bottom:calc(12px + env(safe-area-inset-bottom))}
  /* Mobile: 3 คอลัมน์ */
  .cat-grid{grid-template-columns:repeat(3,1fr)}
}
</style>
</head>
<body>

<!-- ════ LOADING ════ -->
<div class="loading-screen" id="loadingScreen">
  <i class="fas fa-layer-group loading-icon"></i>
  <div class="loading-text">กำลังโหลด...</div>
</div>

<!-- ════ LOGIN ════ -->
<div class="login-screen hidden" id="loginScreen">
  <img src="" alt="Logo" id="loginLogoImg" style="display:none;width:64px;height:64px;object-fit:cover;border-radius:16px;margin-bottom:8px;box-shadow:0 4px 16px rgba(0,0,0,.35)">
  <div class="login-logo" id="loginLogoEmoji">🏭</div>
  <div class="login-title" id="loginTitleText">ระบบคลังอะไหล่</div>
  <div class="login-sub">เข้าสู่ระบบเพื่อทำรายการ</div>
  <div class="login-card">
    <!-- เลือกชื่อ -->
    <div class="login-field" style="position:relative">
      <div class="login-label">ชื่อผู้ใช้งาน</div>
      <div style="position:relative">
        <i class="fas fa-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:13px;pointer-events:none;z-index:1"></i>
        <input class="login-input" id="loginSearch" type="text" placeholder="พิมพ์ค้นหาชื่อ..." autocomplete="off"
          oninput="onLoginSearchInput(this.value)" onfocus="showUserDropdown()" style="padding-left:34px">
      </div>
      <div id="loginDropdown" style="
        display:none;position:absolute;left:0;right:0;
        background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius-sm);
        max-height:220px;overflow-y:auto;z-index:50;margin-top:4px;box-shadow:0 8px 24px rgba(0,0,0,.5)
      "></div>
      <input type="hidden" id="loginUid">
    </div>
    <!-- role indicator -->
    <div class="selected-role-indicator" id="roleIndicator">
      <div class="sri-icon" id="roleIcon">👷</div>
      <div class="sri-info">
        <div class="sri-name" id="roleName"></div>
        <div class="sri-role">
          <span class="sri-role-badge" id="roleBadge">user</span>
        </div>
      </div>
    </div>
    <!-- PIN dots -->
    <div class="login-field" id="pinSection" style="display:none;margin-top:16px">
      <div class="login-label">รหัส PIN</div>
      <div class="pin-display" id="pinDisplay">
        <div class="pin-dot" id="d0"></div>
        <div class="pin-dot" id="d1"></div>
        <div class="pin-dot" id="d2"></div>
        <div class="pin-dot" id="d3"></div>
      </div>
      <div class="numpad">
        <button class="num-btn" onclick="numPress('1')">1</button>
        <button class="num-btn" onclick="numPress('2')">2</button>
        <button class="num-btn" onclick="numPress('3')">3</button>
        <button class="num-btn" onclick="numPress('4')">4</button>
        <button class="num-btn" onclick="numPress('5')">5</button>
        <button class="num-btn" onclick="numPress('6')">6</button>
        <button class="num-btn" onclick="numPress('7')">7</button>
        <button class="num-btn" onclick="numPress('8')">8</button>
        <button class="num-btn" onclick="numPress('9')">9</button>
        <button class="num-btn empty"></button>
        <button class="num-btn" onclick="numPress('0')">0</button>
        <button class="num-btn del" onclick="numDel()"><i class="fas fa-delete-left"></i></button>
      </div>
      <button class="login-btn" id="loginBtn" onclick="doLogin()" disabled>เข้าสู่ระบบ</button>
      <div class="login-error" id="loginError">PIN ไม่ถูกต้อง กรุณาลองใหม่</div>
    </div>
  </div>
  <div class="register-link">
    ยังไม่มีบัญชี? <a onclick="openRegister()">สมัครใช้งาน</a>
  </div>
</div>

<!-- ════ REGISTER MODAL ════ -->
<div class="modal-overlay" id="registerModal">
  <div class="modal-box">
    <div class="modal-handle"></div>
    <div class="modal-title">📝 สมัครใช้งาน</div>
    <div class="modal-sub">กรอกข้อมูลเพื่อขอเปิดบัญชีใหม่</div>
    <div class="reg-error" id="regError"></div>
    <div class="reg-step active" id="regStep1">
      <div class="reg-field">
        <div class="reg-label">ชื่อ-นามสกุล <span style="color:var(--red)">*</span></div>
        <input class="reg-input" id="regName" placeholder="เช่น สมชาย ใจดี" type="text" autocomplete="off">
      </div>
      <div class="reg-field">
        <div class="reg-label">แผนก / ตำแหน่ง</div>
        <input class="reg-input" id="regDept" placeholder="เช่น ช่างซ่อมบำรุง, ฝ่ายผลิต" type="text" autocomplete="off">
      </div>
      <div class="reg-btn-row">
        <button class="reg-cancel-btn" onclick="closeRegister()">ยกเลิก</button>
        <button class="reg-submit-btn" onclick="goRegStep2()">ถัดไป →</button>
      </div>
    </div>
    <div class="reg-step" id="regStep2">
      <div class="reg-field">
        <div class="reg-label" style="text-align:center;margin-bottom:12px">ตั้งรหัส PIN 4 หลัก</div>
        <div class="reg-pin-row" id="regPinDisplay">
          <div class="reg-pin-dot" id="rd0"></div>
          <div class="reg-pin-dot" id="rd1"></div>
          <div class="reg-pin-dot" id="rd2"></div>
          <div class="reg-pin-dot" id="rd3"></div>
        </div>
      </div>
      <div class="reg-numpad">
        <button class="reg-num-btn" onclick="regNumPress('1')">1</button>
        <button class="reg-num-btn" onclick="regNumPress('2')">2</button>
        <button class="reg-num-btn" onclick="regNumPress('3')">3</button>
        <button class="reg-num-btn" onclick="regNumPress('4')">4</button>
        <button class="reg-num-btn" onclick="regNumPress('5')">5</button>
        <button class="reg-num-btn" onclick="regNumPress('6')">6</button>
        <button class="reg-num-btn" onclick="regNumPress('7')">7</button>
        <button class="reg-num-btn" onclick="regNumPress('8')">8</button>
        <button class="reg-num-btn" onclick="regNumPress('9')">9</button>
        <button class="reg-num-btn empty"></button>
        <button class="reg-num-btn" onclick="regNumPress('0')">0</button>
        <button class="reg-num-btn del" onclick="regNumDel()"><i class="fas fa-delete-left"></i></button>
      </div>
      <div class="reg-hint" id="regPinHint">กรุณากรอก PIN 4 หลัก</div>
      <div class="reg-btn-row">
        <button class="reg-cancel-btn" onclick="backRegStep1()">← ย้อนกลับ</button>
        <button class="reg-submit-btn" id="regSubmitBtn" onclick="submitRegister()" disabled>ส่งคำขอสมัคร</button>
      </div>
    </div>
    <div class="reg-step" id="regStep3">
      <div class="reg-success">
        <div class="reg-pending-spinner" id="regSpinner"></div>
        <div class="reg-success-icon approved" id="regApprovedIcon">🎉</div>
        <div class="reg-success-msg" id="regSuccessMsg">ส่งคำขอเรียบร้อย!</div>
        <div class="reg-success-sub" id="regSuccessSub">รอ Admin อนุมัติก่อนเข้าใช้งาน</div>
      </div>
      <button class="reg-submit-btn" style="width:100%;margin-top:8px" onclick="closeRegister()">ปิด</button>
    </div>
  </div>
</div>

<!-- ════ MAIN APP ════ -->
<div id="appWrap">
<div class="topbar">
  <div class="topbar-left">
    <div>
      <div class="topbar-title">ทำรายการ</div>
      <div class="topbar-sub" id="topSub">เบิกของออก</div>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:8px">
    <div class="user-name" id="userName"></div>
    <div style="position:relative;cursor:pointer;width:36px;height:36px;border-radius:50%;background:var(--surface);border:1px solid var(--border2);display:none;align-items:center;justify-content:center" id="retroBellBtn" onclick="openRetroPendingModal()">
      <i class="fas fa-bell" style="color:var(--amber);font-size:14px"></i>
      <span id="retroBellBadge" style="position:absolute;top:-4px;right:-4px;background:var(--red);color:#fff;font-size:9px;font-weight:700;border-radius:999px;min-width:16px;height:16px;display:flex;align-items:center;justify-content:center;padding:0 3px">0</span>
    </div>
    <div style="position:relative;cursor:pointer;width:36px;height:36px;border-radius:50%;background:var(--surface);border:1px solid var(--border2);display:none;align-items:center;justify-content:center" id="approvalBellBtn" onclick="switchTab('mine'); switchMineSub('approval')" title="รายการที่ยื่นไปแล้วรอแอดมินอนุมัติ">
      <i class="fas fa-hourglass-half" style="color:#60a5fa;font-size:13px"></i>
