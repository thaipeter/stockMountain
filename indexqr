  if (!item) return;
  const exist = receiveCart.find(c => c.code === code);
  if (exist) { exist.qty++; }
  else receiveCart.push({ code: item.code, name: item.name, qty: 1, unit: item.unit, imageUrl: item.imageUrl || '' });
