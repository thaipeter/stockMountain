/* ══ REAL-TIME STOCK POLLING (ทุก 3 วิ) ══ */
let _stockPollTimer = null;
let _stockPollInFlight = false;

let _stockPollTickCount = 0;

function startStockPoll() {
  stopStockPoll();
  _stockPollTimer = setInterval(() => {
    if (_stockPollInFlight) return; // กันยิงซ้อนถ้ารอบก่อนหน้ายังไม่เสร็จ
    if (document.querySelector('.sheet.open')) return; // อย่ารีเฟรชทับตอนกำลังดูตะกร้า/ยืนยันรายการ
    _stockPollInFlight = true;
    // ใช้ endpoint เบา ๆ ที่ดึงแค่รหัส+ยอดสต็อก แทนการโหลด inventory ทั้งชุดทุก 3 วิ
    callGAS('webGetStockLevels', [], res => {
      _stockPollInFlight = false;
      if (!res || !res.success) return;
      const hasNewItems = _detectNewCodes(res.items || [], res.tools || []);
      if (hasNewItems) {
        // เจอรายการใหม่ที่ยังไม่มีในเครื่อง -> ดึงข้อมูลเต็มมาเติมให้ครบ (ชื่อ/รูป/หมวดหมู่ ฯลฯ)
        callGAS('getInventoryData', [], data => {
          if (data) {
            allData.items = data.items || allData.items;
            allData.tools = data.tools || allData.tools;
            refreshVisibleStock();
          }
        }, () => {});
      } else {
        applyStockLevels(res.items || [], res.tools || []);
        refreshVisibleStock();
      }
    }, () => { _stockPollInFlight = false; });
    // ทุก ๆ 10 รอบ (~30 วิ) เช็คด้วยว่ารายการรออนุมัติของ user คนนี้ถูกอนุมัติไปหรือยัง
    // เพื่อให้ badge หายไปเองโดยไม่ต้องรอ refresh หน้าใหม่
    _stockPollTickCount++;
    if (_stockPollTickCount % 10 === 0 && me && me.uid) {
      loadMineApproval();
    }
  }, 3000); // อัปเดตยอดสต็อกทุก 3 วินาที
}

function stopStockPoll() {
  if (_stockPollTimer) { clearInterval(_stockPollTimer); _stockPollTimer = null; }
}

// เช็คว่ามีรหัสสินค้า/เครื่องมือใหม่ที่ยังไม่มีในเครื่อง (เพิ่งถูกเพิ่มเข้าระบบจากที่อื่น) หรือไม่
function _detectNewCodes(itemLevels, toolLevels) {
  const knownItemCodes = new Set((allData.items || []).map(i => i.code));
  const knownToolCodes = new Set((allData.tools || []).map(i => i.code));
  const hasNewItem = (itemLevels || []).some(l => !knownItemCodes.has(l.code));
  const hasNewTool = (toolLevels || []).some(l => !knownToolCodes.has(l.code));
  return hasNewItem || hasNewTool;
}

// อัปเดตแค่ตัวเลขสต็อกลงใน allData เดิม (ไม่แตะชื่อ/รูป/หมวดหมู่ ที่โหลดไว้แล้ว)
function applyStockLevels(itemLevels, toolLevels) {
  const applyTo = (list, levels) => {
    if (!list || !list.length) return;
    const map = {};
    levels.forEach(l => { map[l.code] = l.stock; });
    list.forEach(it => { if (map.hasOwnProperty(it.code)) it.stock = map[it.code]; });
  };
  applyTo(allData.items, itemLevels);
  applyTo(allData.tools, toolLevels);
  // sync ยอดสต็อกในตะกร้าที่ยังไม่ยืนยันด้วย เผื่อผู้ใช้เปิดตะกร้าค้างไว้
  [withdrawCart, borrowCart].forEach(cart => {
    (cart || []).forEach(ci => {
      const src = getAllItems().find(i => i.code === ci.code);
      if (src) ci.stock = src.stock;
    });
  });
}

function refreshVisibleStock() {
  ['withdraw', 'borrow'].forEach(mode => {
    renderCats(mode);
    const state = _viewState[mode];
    if (state && !state.onCatScreen) {
      renderList(mode, state.kw || '', state.cat || '__all__');
    }
  });
  renderReturnList();
}

const CAT_ICON = {
  'ระบบน้ำ':'🚰','ไฟฟ้า':'⚡','เครื่องจักร':'⚙️','น้ำมัน':'🛢️',
  'ระบบลม':'💨','เครื่องมือ':'🔧','เครื่องมือไฟฟ้า':'🔌',
  'อะไหล่':'🔩','ของเบ็ดเตล็ด':'📦','Hardware':'🔩',
  'Power Tools':'🔌','default':'📦'
};
function catIcon(cat) { return CAT_ICON[cat] || CAT_ICON['default']; }

function renderCats(mode) {
  const gridId = mode === 'withdraw' ? 'wCatGrid' : 'bCatGrid';
  const grid   = document.getElementById(gridId);
  const items  = getAllItems();
  const catMap = {};
  items.forEach(i => {
    const c = i.category || 'อื่นๆ';
    if (!catMap[c]) catMap[c] = { count: 0, availCount: 0, hasStock: false };
    catMap[c].count++;
    if (i.stock > 0) { catMap[c].hasStock = true; catMap[c].availCount++; }
  });
  const cats = Object.keys(catMap).sort();
  grid.innerHTML =
    `<div class="cat-card all-card" onclick="selectCat('${mode}','__all__')">
      <div class="cat-icon">🗂️</div>
      <div>
        <div class="cat-name">ทั้งหมด</div>
        <div class="cat-count">${items.length} รายการ</div>
      </div>
    </div>` +
    cats.map(c => `
    <div class="cat-card" onclick="selectCat('${mode}','${esc(c)}')">
      <div class="cat-icon">${catIcon(c)}</div>
      <div class="cat-name">${esc(c)}</div>
      <div class="cat-count">${catMap[c].availCount}/${catMap[c].count} รายการ${catMap[c].hasStock ? '' : ' · <span style="color:var(--red)">หมด</span>'}</div>
    </div>`).join('');
}

// เก็บ state หมวด/คำค้นหาปัจจุบันของแต่ละโหมด ไว้ให้ stock poll เรียก renderList ซ้ำได้ถูกต้อง
let _viewState = {
  withdraw: { cat: '__all__', kw: '', onCatScreen: true },
  borrow:   { cat: '__all__', kw: '', onCatScreen: true }
};

function selectCat(mode, cat) {
  const catScreen = document.getElementById(mode === 'withdraw' ? 'wCatScreen' : 'bCatScreen');
  const backRow   = document.getElementById(mode === 'withdraw' ? 'wBackRow' : 'bBackRow');
  const listEl    = document.getElementById(mode === 'withdraw' ? 'withdrawList' : 'borrowList');
  const labelEl   = document.getElementById(mode === 'withdraw' ? 'wActiveCat' : 'bActiveCat');
  catScreen.classList.add('hidden');
  backRow.classList.remove('hidden');
  listEl.classList.remove('hidden');
  labelEl.textContent = cat === '__all__' ? 'ทั้งหมด' : cat;
  _viewState[mode] = { cat: cat, kw: '' };
  renderList(mode, '', cat);
}

function backToCat(mode) {
  const catScreen = document.getElementById(mode === 'withdraw' ? 'wCatScreen' : 'bCatScreen');
  const backRow   = document.getElementById(mode === 'withdraw' ? 'wBackRow' : 'bBackRow');
  const listEl    = document.getElementById(mode === 'withdraw' ? 'withdrawList' : 'borrowList');
  const searchEl  = document.getElementById(mode === 'withdraw' ? 'withdrawSearch' : 'borrowSearch');
  catScreen.classList.remove('hidden');
  backRow.classList.add('hidden');
  listEl.classList.add('hidden');
  if (searchEl) searchEl.value = '';
  _viewState[mode] = { cat: '__all__', kw: '', onCatScreen: true };
}

function onSearchInput(kw, mode) {
  if (kw.trim().length > 0) {
    const catScreen = document.getElementById(mode === 'withdraw' ? 'wCatScreen' : 'bCatScreen');
    const backRow   = document.getElementById(mode === 'withdraw' ? 'wBackRow' : 'bBackRow');
    const listEl    = document.getElementById(mode === 'withdraw' ? 'withdrawList' : 'borrowList');
    const labelEl   = document.getElementById(mode === 'withdraw' ? 'wActiveCat' : 'bActiveCat');
    catScreen.classList.add('hidden');
    backRow.classList.remove('hidden');
    listEl.classList.remove('hidden');
    labelEl.textContent = `"${kw.trim()}"`;
    _viewState[mode] = { cat: '__all__', kw: kw.toLowerCase().trim() };
    renderList(mode, kw.toLowerCase().trim(), '__all__');
  } else {
    backToCat(mode);
  }
}

function switchTab(tab) {
  ['withdraw','borrow','receive','mine','newitem','stocktake'].forEach(t => {
    const c = document.getElementById('content' + cap(t));
    if (c) { c.classList.remove('active'); c.style.display = 'none'; }
    const btn = document.getElementById('tab' + cap(t));
    if (!btn) return; // return ออกจาก forEach callback เท่านั้น — ถูกต้อง
    btn.className = 'tab-btn' + (t === tab ? ' active-' + t : '');
  });
  const active = document.getElementById('content' + cap(tab));
  if (active) { active.style.display = 'flex'; active.classList.add('active'); }
  const subs = { withdraw: 'เบิกของออก', borrow: 'ยืม / คืนเครื่องมือ', receive: 'รับสินค้าเข้าคลัง', mine: 'ประวัติและสถานะของฉัน', newitem: 'ขึ้นทะเบียนรายการใหม่', stocktake: 'นับสต็อกประจำเดือน' };
  document.getElementById('topSub').textContent = subs[tab] || '';
  if (tab === 'mine') loadMineData();
  if (tab === 'newitem') niInit();
  if (tab === 'stocktake') stLoad();
  // บันทึก tab ล่าสุดเพื่อ restore ถ้าหน้า reload
  try { sessionStorage.setItem('lastTab', tab); } catch(e) {}
}

function switchBorrowSub(sub) {
  ['borrow','return'].forEach(s => {
    document.getElementById('section' + cap(s)).classList.toggle('active', s === sub);
    document.getElementById('sub' + cap(s) + 'Btn').classList.toggle('active', s === sub);
  });
}

/* ══ STOCK TAKE (นับสต็อกประจำเดือน) ══ */
let stState = { sessionId: null, items: [], loaded: false };

function stLoad() {
  const listEl = document.getElementById('stList');
  if (!stState.loaded) listEl.innerHTML = '<div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>กำลังโหลดรายการนับสต็อก...</p></div>';
  callGAS('webGetStockTakeProgress', [{ role: me.role, userName: me.name }], res => {
    stState.sessionId = res.sessionId;
    stState.items = res.items || [];
    stState.loaded = true;
    const y = res.year, m = res.month;
    document.getElementById('stSessionLabel').textContent = 'รอบนับเดือน ' + String(m).padStart(2,'0') + '/' + (y + 543) + (res.status === 'closed' ? ' (ปิดรอบแล้ว)' : '');
    document.getElementById('stProgressBadge').textContent = res.countedItems + '/' + res.totalItems;
    const pct = res.totalItems ? Math.round(res.countedItems / res.totalItems * 100) : 0;
    document.getElementById('stProgressBar').style.width = pct + '%';
    document.getElementById('stCloseBar').style.display = (me.role === 'admin' && res.status !== 'closed') ? 'block' : 'none';
    stRender(document.getElementById('stSearchInput').value || '');
  }, err => {
    listEl.innerHTML = '<div class="empty-state"><i class="fas fa-triangle-exclamation"></i><p>โหลดไม่สำเร็จ: ' + esc(String(err)) + '</p></div>';
  });
}

function stRender(kw) {
  const el = document.getElementById('stList');
  kw = (kw || '').toLowerCase();
  const items = stState.items.filter(i => !kw || i.name.toLowerCase().includes(kw) || i.code.toLowerCase().includes(kw));
  if (!items.length) { el.innerHTML = '<div class="empty-state"><i class="fas fa-box-open"></i><p>ไม่พบสินค้า</p></div>'; return; }
  // ที่ยังไม่นับขึ้นก่อน ตามด้วยที่นับแล้ว
  items.sort((a, b) => (a.counted === b.counted) ? 0 : (a.counted ? 1 : -1));
  el.innerHTML = items.map(function(item) {
    const diffBadge = item.counted
      ? (item.diff === 0
          ? '<span style="color:#22c55e;font-size:11px"><i class="fas fa-check-circle"></i> ตรงกับระบบ</span>'
          : '<span style="color:' + (item.diff > 0 ? '#22c55e' : '#ef4444') + ';font-size:11px"><i class="fas fa-exclamation-circle"></i> ' + (item.diff > 0 ? '+' : '') + item.diff + ' จากระบบ</span>')
      : '<span style="color:var(--text-dim);font-size:11px">ยังไม่ได้นับ</span>';
    return '<div class="item-card" style="' + (item.counted ? 'opacity:.7;' : '') + 'cursor:pointer" onclick="stOpenCount(\'' + item.code + '\')">'
      + '<div class="item-icon" style="width:46px;height:46px;border-radius:8px;background:var(--surface);border:1px solid var(--border2);flex-shrink:0;display:flex;align-items:center;justify-content:center">'
      + (item.counted ? '<i class="fas fa-check" style="color:#22c55e"></i>' : '<i class="fas fa-clipboard-list" style="color:var(--text-dim)"></i>')
      + '</div>'
      + '<div class="item-info">'
      + '<div class="item-name">' + esc(item.name) + '</div>'
      + '<div class="item-code">' + item.code + '</div>'
      + diffBadge
      + '</div>'
      + '<div class="item-stock">'
      + '<div class="stock-num stock-ok">' + (item.counted ? item.countedQty : item.systemStock) + '</div>'
      + '<div class="stock-unit">' + esc(item.unit) + '</div>'
      + '</div>'
      + '</div>';
  }).join('');
}

function stOpenCount(code) {
  const item = stState.items.find(i => i.code === code);
  if (!item) return;
  Swal.fire({
    title: esc(item.name),
    html: '<div style="font-size:13px;color:#9aa4b2;margin-bottom:10px">รหัส ' + item.code + ' • ระบบมี ' + item.systemStock + ' ' + esc(item.unit) + '</div>',
    input: 'number',
    inputValue: item.counted ? item.countedQty : item.systemStock,
    inputAttributes: { min: 0, step: 1 },
    background: '#1a1f2e', color: '#e0e0e0',
    showCancelButton: true,
    confirmButtonText: 'บันทึกยอดนับ',
    cancelButtonText: 'ยกเลิก',
    confirmButtonColor: '#f59e0b',
    inputValidator: v => { if (v === '' || v === null || Number(v) < 0) return 'กรุณากรอกจำนวนที่นับได้'; }
  }).then(r => {
    if (!r.isConfirmed) return;
    stSaveCount(code, Number(r.value));
  });
}

function stSaveCount(code, countedQty) {
  callGAS('webSubmitStockCount', [{
    sessionId: stState.sessionId, itemCode: code, countedQty: countedQty,
    role: me.role, userName: me.name, source: 'scan'
  }], res => {
    showToast(res.diff === 0 ? 'ยอดตรง บันทึกแล้ว' : ('ปรับยอด ' + (res.diff > 0 ? '+' : '') + res.diff + ' แล้ว'), 'success');
    stLoad();
  }, err => {
    Swal.fire({ icon: 'error', title: 'บันทึกไม่สำเร็จ', text: String(err), background: '#1a1f2e', color: '#e0e0e0' });
  });
}

function stCloseSession() {
  const remaining = stState.items.filter(i => !i.counted).length;
  Swal.fire({
    icon: remaining > 0 ? 'warning' : 'question',
    title: 'ปิดรอบนับสต็อกเดือนนี้?',
    text: remaining > 0 ? ('ยังเหลือ ' + remaining + ' รายการที่ยังไม่ได้นับ ปิดรอบเลยไหม?') : 'นับครบทุกรายการแล้ว',
    showCancelButton: true, confirmButtonText: 'ปิดรอบ', cancelButtonText: 'ยกเลิก',
    background: '#1a1f2e', color: '#e0e0e0', confirmButtonColor: '#f59e0b'
  }).then(r => {
    if (!r.isConfirmed) return;
    callGAS('webCloseStockTake', [{ sessionId: stState.sessionId, role: me.role, userName: me.name }], () => {
      showToast('ปิดรอบนับสต็อกแล้ว', 'success');
      stLoad();
    }, err => Swal.fire({ icon: 'error', title: 'ปิดรอบไม่สำเร็จ', text: String(err), background: '#1a1f2e', color: '#e0e0e0' }));
  });
}

/* ══ ITEMS ══ */
function getAllItems() { return [...(allData.items || []), ...(allData.tools || [])]; }

function renderList(mode, kw, cat) {
  const el   = document.getElementById(mode === 'withdraw' ? 'withdrawList' : 'borrowList');
  const cart = mode === 'withdraw' ? withdrawCart : borrowCart;
  let list   = getAllItems();
  if (cat && cat !== '__all__') list = list.filter(i => (i.category || 'อื่นๆ') === cat);
  if (kw) list = list.filter(i => i.name.toLowerCase().includes(kw) || i.code.toLowerCase().includes(kw));
  if (!list.length) {
    el.innerHTML = '<div class="empty-state"><i class="fas fa-box-open"></i><p>' + (kw ? 'ไม่พบ "' + esc(kw) + '"' : 'ไม่มีสินค้าในหมวดนี้') + '</p></div>';
    return;
  }
  el.innerHTML = list.map(function(item) {
    const inCart = cart.find(function(c) { return c.code === item.code; });
    const sc     = item.stock <= 0 ? 'stock-zero' : item.stock <= (item.min || 0) ? 'stock-low' : 'stock-ok';
    const imgUrl = getProxyImgUrl(item.imageUrl);
    const iconHtml = imgUrl
      ? '<img src="' + imgUrl + '" alt="' + esc(item.name) + '" style="width:100%;height:100%;object-fit:cover;border-radius:6px" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'block\'">'
        + '<span style="display:none;font-size:18px">📦</span>'
      : '<span style="font-size:18px">📦</span>';
    const imgClickHtml = imgUrl
      ? '<div style="position:relative;width:56px;height:56px;overflow:hidden;border-radius:10px;background:var(--surface);border:1px solid var(--border2);flex-shrink:0;cursor:zoom-in" onclick="event.stopPropagation();showItemGallery(\'' + item.code + '\',\'' + esc(item.name) + '\')">'        + '<img src="' + imgUrl + '" style="width:100%;height:100%;object-fit:cover;border-radius:10px" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">'        + (item.images && item.images.length > 1 ? '<div style="position:absolute;bottom:2px;right:2px;background:rgba(0,0,0,.6);color:#fff;font-size:9px;padding:1px 4px;border-radius:6px">' + item.images.length + '</div>' : '')        + '<div style="display:none;width:100%;height:100%;align-items:center;justify-content:center;font-size:22px">📦</div></div>'      : '<div style="width:56px;height:56px;border-radius:10px;background:var(--surface);border:1px solid var(--border2);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:22px">📦</div>';
    return '<div class="item-card' + (inCart ? ' in-cart' : '') + '" style="padding:10px 12px">'      + imgClickHtml      + '<div class="item-info" style="flex:1;min-width:0" onclick="addToCart(\'' + item.code + '\',\'' + mode + '\')">'      + '<div class="item-name">' + esc(item.name) + '</div>'      + '<div class="item-code">' + item.code + '</div>'      + (inCart ? '<div class="in-cart-badge"><i class="fas fa-check-circle"></i> ในตะกร้า ×' + inCart.qty + '</div>' : '')      + '</div>'      + '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0">'      + '<div class="item-stock" style="text-align:right"><div class="stock-num ' + sc + '">' + item.stock + '</div><div class="stock-unit">' + item.unit + '</div></div>'      + '<button onclick="event.stopPropagation();addToCart(\'' + item.code + '\',\'' + mode + '\')" style="background:' + (inCart ? 'var(--green)' : 'var(--amber)') + ';color:#111;border:none;border-radius:20px;padding:3px 12px;font-size:11px;font-weight:700;cursor:pointer">'      + (inCart ? '✓ เพิ่ม' : '+ เพิ่ม') + '</button>'      + '</div>'      + '</div>';
  }).join('');
}

function renderReturnList() {
  const borrows = (allData.activeBorrows || []).filter(b => me.role === 'admin' || b.borrower === me.name || b.userId === me.uid);
